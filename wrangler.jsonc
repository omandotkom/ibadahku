{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ibadahku",
  "main": "workers/index.js",
  "compatibility_date": "2026-02-07",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "ibadahku",
      "database_id": "904ad355-7eaf-4e45-9137-c5d9256f429c"
    }
  ],
  "r2_buckets": [
    {
      "binding": "PACKAGE_IMAGES",
      "bucket_name": "ibadahku"
    }
  ]
}
